---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CartDrawer from '../components/CartDrawer.tsx';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Penalty Box — Darren McCarty. 4x Stanley Cup Champion. Detroit Red Wings.',
  ogImage = '/images/darren/Darren-Shoot-010.JPG',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, 'https://penaltybox25.com');

const shopifyDomain = process.env.SHOPIFY_STORE_DOMAIN || '';
const shopifyToken = process.env.SHOPIFY_STOREFRONT_ACCESS_TOKEN || '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, 'https://penaltybox25.com').href} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:site_name" content="Penalty Box" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, 'https://penaltybox25.com').href} />

    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-black text-white">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CartDrawer client:load />
    <script define:vars={{ shopifyDomain, shopifyToken }}>
      window.__SHOPIFY_DOMAIN__ = shopifyDomain;
      window.__SHOPIFY_TOKEN__ = shopifyToken;
    </script>
  </body>
</html>
