---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Cart | Penalty Box">
  <div class="pt-20 sm:pt-24">
    <section class="py-12 sm:py-16 px-4 sm:px-6 lg:px-8 max-w-3xl mx-auto">
      <h1 class="text-3xl sm:text-4xl font-black uppercase tracking-tight mb-8 text-center">
        Your Cart
      </h1>

      <div id="cart-page-content" class="text-center py-16">
        <svg class="w-16 h-16 mx-auto text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        <p class="text-gray-400 mb-6">Your cart is empty.</p>
        <a
          href="/shop"
          class="inline-block bg-redwings hover:bg-redwings-dark text-white font-bold py-3 px-8 rounded-lg transition-colors duration-200"
        >
          Continue Shopping
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // On mobile, open the cart drawer instead of showing this page
  import { openCart, $cart } from '../lib/cart';

  const cart = $cart.get();
  if (cart && cart.lines.length > 0) {
    openCart();
  }
</script>
