---
interface Props {
  image: string;
  imageAlt: string;
  title?: string;
  subtitle?: string;
  overlay?: boolean;
  fullHeight?: boolean;
}

const {
  image,
  imageAlt,
  title,
  subtitle,
  overlay = true,
  fullHeight = false,
} = Astro.props;
---

<section class:list={['relative flex items-center justify-center', fullHeight ? 'min-h-screen' : 'min-h-[60vh]']}>
  <img
    src={image}
    alt={imageAlt}
    class="absolute inset-0 w-full h-full object-cover object-top"
  />
  {overlay && <div class="absolute inset-0 bg-black/60" />}
  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <slot />
  </div>
</section>
